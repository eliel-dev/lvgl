<?xml version="1.0" encoding="UTF-8"?>

<!--
  Cyberpunk 2077 Watchface – 128×64
  Layout zones:
    y  0- 8   top bar (magenta)
    y  9       cyan separator
    y 10-37   main: clock (left) | night-city skyline (right, x=70-126)
    y 38-42   seconds progress bar
    y 43       yellow separator + ticks
    y 44-53   info row: role | net status
    y 54-58   HP bar (left) + BAT bar (right)
    y 59-63   footer strip (dark magenta + stripes)
-->

<screen width="128" height="64" bg_color="#030A14">

  <view>

    <!-- ── ROOT ─────────────────────────────────────────────────────── -->
    <lv_obj x="0" y="0" width="128" height="64"
            style_bg_color="#030A14"
            style_border_width="0"
            style_radius="0"
            style_pad_all="0">

      <!-- ── TOP BAR ────────────────────────────────────────────────── -->
      <lv_obj x="0" y="0" width="128" height="9"
              style_bg_color="#FF0055"
              style_border_width="0"
              style_radius="0"
              style_pad_all="0">

        <!-- side accents -->
        <lv_obj x="0"   y="0" width="5" height="9"
                style_bg_color="#880033" style_border_width="0" style_radius="0"/>
        <lv_obj x="123" y="0" width="5" height="9"
                style_bg_color="#880033" style_border_width="0" style_radius="0"/>

        <!-- title -->
        <lv_label x="9" y="0" text="&lt; NIGHT CITY * 2077 &gt;"
                  style_text_font="lv_font_montserrat_10"
                  style_text_color="#D0EEFF"/>
      </lv_obj>

      <!-- ── CYAN SEPARATOR ─────────────────────────────────────────── -->
      <lv_obj x="0" y="9" width="128" height="1"
              style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>

      <!-- ── CLOCK ZONE ──────────────────────────────────────────────── -->
      <!-- corner brackets (TL) -->
      <lv_obj x="1" y="10" width="6" height="1"
              style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>
      <lv_obj x="1" y="10" width="1" height="6"
              style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>
      <!-- corner brackets (BL) -->
      <lv_obj x="1" y="37" width="6" height="1"
              style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>
      <lv_obj x="1" y="32" width="1" height="6"
              style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>

      <!-- clock glow backdrop -->
      <lv_obj x="2" y="11" width="65" height="26"
              style_bg_color="#06101E" style_border_width="0" style_radius="0"/>

      <!-- clock digits -->
      <lv_label x="3" y="10" text="22:47"
                style_text_font="lv_font_montserrat_28"
                style_text_color="#00F5FF"/>

      <!-- pulse dot -->
      <lv_obj x="62" y="20" width="4" height="4"
              style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>

      <!-- glitch accent stripes -->
      <lv_obj x="60" y="14" width="7" height="1"
              style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
      <lv_obj x="63" y="27" width="4" height="1"
              style_bg_color="#FFE000" style_border_width="0" style_radius="0"/>
      <lv_obj x="61" y="31" width="6" height="1"
              style_bg_color="#6600CC" style_border_width="0" style_radius="0"/>

      <!-- vertical divider -->
      <lv_obj x="68" y="10" width="1" height="28"
              style_bg_color="#6600CC"
              style_bg_opa="153"
              style_border_width="0" style_radius="0"/>

      <!-- ── SKYLINE PANEL ─────────────────────────────────────────── -->
      <lv_obj x="70" y="10" width="57" height="28"
              style_bg_color="#06101E"
              style_border_color="#FF0055"
              style_border_width="1"
              style_radius="0"
              style_pad_all="0">

        <!-- buildings -->
        <lv_obj x="2"  y="11" width="5" height="12" style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="8"  y="15" width="3" height="8"  style_bg_color="#44006A" style_border_width="0" style_radius="0"/>
        <lv_obj x="12" y="5"  width="4" height="18" style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>
        <lv_obj x="17" y="17" width="3" height="6"  style_bg_color="#0D1F3C" style_border_width="0" style_radius="0"/>
        <lv_obj x="21" y="9"  width="5" height="14" style_bg_color="#FF44AA" style_border_width="0" style_radius="0"/>
        <lv_obj x="27" y="13" width="3" height="10" style_bg_color="#220044" style_border_width="0" style_radius="0"/>
        <lv_obj x="31" y="3"  width="5" height="20" style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="37" y="13" width="4" height="10" style_bg_color="#6600CC" style_border_width="0" style_radius="0"/>
        <lv_obj x="42" y="17" width="4" height="6"  style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>
        <lv_obj x="47" y="9"  width="5" height="14" style_bg_color="#FF44AA" style_border_width="0" style_radius="0"/>

        <!-- ground line -->
        <lv_obj x="1" y="23" width="54" height="1"
                style_bg_color="#FFE000" style_border_width="0" style_radius="0"/>

        <!-- antenna on tallest building -->
        <lv_obj x="33" y="1" width="1" height="3"
                style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="32" y="1" width="3" height="1"
                style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>

        <!-- NC-NET label -->
        <lv_label x="2" y="13" text="NC-NET"
                  style_text_font="lv_font_montserrat_10"
                  style_text_color="#FFE000"/>

        <!-- top-right corner accent -->
        <lv_obj x="50" y="1" width="5" height="1"
                style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>
        <lv_obj x="54" y="1" width="1" height="4"
                style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>
      </lv_obj>

      <!-- ── SECONDS BAR ─────────────────────────────────────────────── -->
      <lv_obj x="3" y="38" width="56" height="5"
              style_bg_color="#0D1F3C"
              style_border_color="#00F5FF"
              style_border_width="1"
              style_radius="0"
              style_pad_all="0">
        <lv_obj x="1" y="1" width="27" height="3"
                style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>
      </lv_obj>
      <!-- SEC indicator dot -->
      <lv_obj x="61" y="39" width="3" height="3"
              style_bg_color="#00F5FF" style_border_width="0" style_radius="0"/>

      <!-- ── YELLOW SEPARATOR ───────────────────────────────────────── -->
      <lv_obj x="0" y="43" width="128" height="1"
              style_bg_color="#FFE000" style_border_width="0" style_radius="0"/>

      <!-- ── INFO ROW ────────────────────────────────────────────────── -->
      <lv_obj x="2" y="45" width="2" height="8"
              style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
      <lv_label x="6" y="44" text="NTRN V"
                style_text_font="lv_font_montserrat_10"
                style_text_color="#FF0055"/>
      <lv_obj x="52" y="48" width="2" height="2"
              style_bg_color="#FFE000" style_border_width="0" style_radius="0"/>
      <lv_label x="56" y="44" text="JACKED-IN"
                style_text_font="lv_font_montserrat_10"
                style_text_color="#00FF88"/>

      <!-- ── HP BAR ─────────────────────────────────────────────────── -->
      <lv_obj x="2" y="54" width="56" height="5"
              style_bg_color="#0D1F3C"
              style_border_color="#00FF88"
              style_border_width="1"
              style_radius="0"
              style_pad_all="0">
        <lv_obj x="1" y="1" width="42" height="3"
                style_bg_color="#00FF88" style_border_width="0" style_radius="0"/>
      </lv_obj>
      <lv_obj x="60" y="54" width="2" height="5"
              style_bg_color="#00FF88" style_border_width="0" style_radius="0"/>

      <!-- ── BAT BAR ────────────────────────────────────────────────── -->
      <lv_obj x="70" y="54" width="56" height="5"
              style_bg_color="#0D1F3C"
              style_border_color="#FFE000"
              style_border_width="1"
              style_radius="0"
              style_pad_all="0">
        <lv_obj x="1" y="1" width="35" height="3"
                style_bg_color="#FFE000" style_border_width="0" style_radius="0"/>
      </lv_obj>
      <lv_obj x="126" y="54" width="2" height="5"
              style_bg_color="#FFE000" style_border_width="0" style_radius="0"/>

      <!-- ── FOOTER STRIP ───────────────────────────────────────────── -->
      <lv_obj x="0" y="59" width="128" height="5"
              style_bg_color="#880033" style_border_width="0" style_radius="0"
              style_pad_all="0">
        <!-- corner squares -->
        <lv_obj x="0"   y="0" width="5" height="5"
                style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="123" y="0" width="5" height="5"
                style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <!-- stripe pattern -->
        <lv_obj x="15"  y="0" width="2" height="5" style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="33"  y="0" width="2" height="5" style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="51"  y="0" width="2" height="5" style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="69"  y="0" width="2" height="5" style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="87"  y="0" width="2" height="5" style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
        <lv_obj x="105" y="0" width="2" height="5" style_bg_color="#FF0055" style_border_width="0" style_radius="0"/>
      </lv_obj>

    </lv_obj>

  </view>

</screen>
